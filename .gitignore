# ---- Sensitive: secret VALUES — NEVER commit. Drop real keys in secrets/keys.local.env.
#      The committed registry (names/purpose/status, NO values) lives in docs/SECRETS.md ----
secrets/

# ---- Sensitive: never commit customer data or uploaded files (PII) ----
data/
*.db
*.sqlite
*.sqlite3
uploads/
# (uploads holds driver's licenses, COI, customer docs — keep OUT of git;
#  on the host these live on the Render persistent disk at /data/uploads)

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ---- Local / editor / OS ----
.vercel
.env
.env.*
*.log
/tmp/
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---- Misc scratch ----
_seabreeze_docs/
*.zip
.preview/

.env*.local

# ---- Multi-agent coordination: local state + scratch (keep out of git) ----
.claude/
_blob_rescue/
scripts/_ws_*.json
scripts/_ws_seed.json
static/_wsg.json
dev_notes.txt
scripts/_ws_guids.json
dispatch_log.jsonl
TEST_REPORT.md
migration/

# ---- packet_builder_handoff: exclude the 1.1 GB SeaBreeze permit library (PDFs,
#      images, calibration files) and compiled Python.  The Python source files
#      (build.py, stamp_maps.py, etc.) ARE committed so Render can import them.
#      Keep ONLY *.py and *.md; exclude everything else inside the library. ----
packet_builder_handoff/SeaBreeze_Permit_Library/
packet_builder_handoff/SeaBreeze_Ops/__pycache__/
packet_builder_handoff/permit_packet_builder/__pycache__/
packet_builder_handoff/permit_packet_builder/_speccheck/
packet_builder_handoff/__pycache__/
packet_builder_handoff/**/*.pyc
packet_builder_handoff/**/__pycache__/
packet_builder_handoff/SeaBreeze_Ops/data/
packet_builder_handoff/SeaBreeze_Ops/output/
packet_builder_handoff/SeaBreeze_Ops/uploads/
packet_builder_handoff/run_builder_hidden.vbs
.repair/

# --- large binary artifacts: NEVER version (2.6GB combined) ---
packet_builder_handoff/dist/
packet_builder_handoff/approved_permit_examples/
packet_builder_handoff/pending_forms/
packet_builder_handoff/permit_packet_builder/audit_reports/
*.bak-preforms
.repair/
